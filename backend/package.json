{
  "name": "operations-analytics-backend-scaffold",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "test": "node --test",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "check": "prettier --write . && eslint . --fix",
    "check:licenses": "license-checker --production --failOn \"GPL;AGPL;LGPL\" || exit 1",
    "prepare": "husky install"
  },
  "devDependencies": {
    "@types/express": "^5.0.3",
    "@types/node": "^24.5.2",
    "eslint": "^9.0.0",
    "husky": "^9.0.0",
    "license-checker": "^25.0.1",
    "lint-staged": "^15.0.0",
    "prettier": "^3.0.0",
    "typescript": "^5.9.2"
  },
  "lint-staged": {
    "*.{js,ts,json,md}": [
      "npm --prefix backend exec -- prettier --write",
      "npm --prefix backend exec -- eslint --fix --config backend/eslint.config.js"
    ]
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^17.3.1",
    "express": "^5.1.0",
    "helmet": "^8.1.0",
    "pg": "^8.16.3"
  }
}
